# ============================================================
# SIGER PANGAN — Root Environment Variables
# Copy file ini menjadi .env dan sesuaikan nilainya
# ============================================================

# PostgreSQL
POSTGRES_DB=siger_pangan
POSTGRES_USER=siger_user
POSTGRES_PASSWORD=ganti_dengan_password_aman

# Redis
REDIS_PASSWORD=ganti_dengan_password_redis

# MeiliSearch
MEILI_MASTER_KEY=ganti_dengan_master_key_panjang

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=ganti_dengan_password_grafana
