# ============================================================
# SERVICE WEB SCRAPER — Environment Variables
# Copy file ini menjadi .env
# ============================================================

# App
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://siger_user:siger_dev_password@localhost:5432/siger_pangan_dev

# Redis (format: redis://:password@host:port)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# gRPC — NLP Service
NLP_GRPC_URL=localhost:50051

# MeiliSearch
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=

# JWT (Authentication — isi dengan string rahasia yang panjang)
JWT_SECRET=ganti_dengan_string_rahasia_panjang
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Scraping
SCRAPER_CRON=0 */6 * * *
PIHPS_BASE_URL=https://panelharga.badanpangan.go.id
