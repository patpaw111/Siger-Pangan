# ============================================================
# SERVICE WEB SCRAPER — Environment Variables (Development)
# Host menggunakan nama service Docker Compose
# ============================================================

# App
NODE_ENV=development
PORT=3000

# Database (host = nama service di docker-compose.dev.yml)
DATABASE_URL=postgresql://siger_user:siger_dev_password@postgres:5432/siger_pangan_dev

# Redis (host = nama service di docker-compose.dev.yml)
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# gRPC — NLP Service (belum aktif di dev phase ini)
NLP_GRPC_URL=service-nlp:50051

# MeiliSearch
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_API_KEY=

# JWT
JWT_SECRET=siger_pangan_dev_secret_ganti_di_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Scraping
SCRAPER_CRON=0 */6 * * *
PIHPS_BASE_URL=https://panelharga.badanpangan.go.id

# CORS
# Biarkan kosong atau isi "*" untuk mode development agar semua jalan
ALLOWED_ORIGINS=
